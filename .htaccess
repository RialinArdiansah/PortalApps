RewriteEngine On

# ── Security: Block access to sensitive files ───────────────────
RewriteRule ^(core|controllers|models|views|database|vendor|storage|deploy)/ - [F,L]
RewriteRule ^config\.php$ - [F,L]
RewriteRule ^routes\.php$ - [F,L]
RewriteRule ^\.env - [F,L]
RewriteRule ^\.git - [F,L]
RewriteRule ^\.htaccess$ - [F,L]

# Block access to non-public file types
RewriteRule \.(md|sql|log|ini|yml|yaml|xml|lock|json)$ - [F,L]

# ── Security Headers ────────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    # Remove server signature
    Header unset X-Powered-By
</IfModule>

# ── Route all requests to front controller ──────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ public/index.php [L,QSA]
