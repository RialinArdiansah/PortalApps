; ═══════════════════════════════════════════════════════════════════
; Portal Sertifikasi — Environment Configuration Template
; ═══════════════════════════════════════════════════════════════════
; Copy this file to .env and fill in the values for your server.

; Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com

; Database
DB_HOST=127.0.0.1
DB_NAME=portal_sertifikasi
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

; Timezone
APP_TIMEZONE=Asia/Jakarta
